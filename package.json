{
  "name": "ai-email-agent",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev:backend": "npm run dev --prefix backend",
    "start:backend": "npm start --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "build:frontend": "npm run build --prefix frontend",
    "dev": "concurrently -k -n BACKEND,FRONTEND -c green,cyan \"npm run dev:backend\" \"npm run dev:frontend\""
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
